{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "apiVersion": {
      "const": "gateway.networking.k8s.io/v1"
    },
    "kind": {
      "const": "GatewayClass"
    },
    "metadata": {
      "properties": {
        "name": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "spec": {
      "properties": {
        "controllerName": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "controllerName"
      ],
      "type": "object"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "type": "object"
}
