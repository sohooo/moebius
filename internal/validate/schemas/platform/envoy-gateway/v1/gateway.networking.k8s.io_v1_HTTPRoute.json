{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "apiVersion": {
      "const": "gateway.networking.k8s.io/v1"
    },
    "kind": {
      "const": "HTTPRoute"
    },
    "metadata": {
      "properties": {
        "name": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "spec": {
      "properties": {
        "hostnames": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "rules": {
          "items": {
            "properties": {
              "backendRefs": {
                "items": {
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "port": {
                      "type": "integer"
                    }
                  },
                  "required": [
                    "name"
                  ],
                  "type": "object"
                },
                "type": "array"
              }
            },
            "type": "object"
          },
          "type": "array"
        }
      },
      "type": "object"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "type": "object"
}
