{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "apiVersion": {
      "const": "gateway.networking.k8s.io/v1"
    },
    "kind": {
      "const": "Gateway"
    },
    "metadata": {
      "properties": {
        "name": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "spec": {
      "properties": {
        "listeners": {
          "items": {
            "properties": {
              "name": {
                "type": "string"
              },
              "port": {
                "type": "integer"
              },
              "protocol": {
                "type": "string"
              },
              "tls": {
                "type": "object"
              }
            },
            "required": [
              "name",
              "port",
              "protocol"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "required": [
        "listeners"
      ],
      "type": "object"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "type": "object"
}
