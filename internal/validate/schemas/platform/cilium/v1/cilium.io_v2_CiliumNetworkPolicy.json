{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "cilium.io/v2" },
    "kind": { "const": "CiliumNetworkPolicy" },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "spec": {
      "type": "object",
      "properties": {
        "endpointSelector": { "type": "object" },
        "ingress": { "type": "array" },
        "egress": { "type": "array" }
      }
    }
  }
}
