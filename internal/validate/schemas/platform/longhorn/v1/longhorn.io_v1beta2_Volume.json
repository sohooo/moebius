{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "apiVersion": {
      "const": "longhorn.io/v1beta2"
    },
    "kind": {
      "const": "Volume"
    },
    "metadata": {
      "properties": {
        "name": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "spec": {
      "properties": {
        "accessMode": {
          "type": "string"
        },
        "backupTargetName": {
          "type": "string"
        },
        "dataLocality": {
          "type": "string"
        },
        "numberOfReplicas": {
          "type": "integer"
        }
      },
      "type": "object"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "type": "object"
}
