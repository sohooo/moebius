{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "apiVersion": {
      "const": "postgresql.cnpg.io/v1"
    },
    "kind": {
      "const": "Cluster"
    },
    "metadata": {
      "properties": {
        "name": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "spec": {
      "properties": {
        "backup": {
          "type": "object"
        },
        "bootstrap": {
          "type": "object"
        },
        "externalClusters": {
          "type": "array"
        },
        "imageName": {
          "type": "string"
        },
        "instances": {
          "type": "integer"
        },
        "storage": {
          "type": "object"
        },
        "walStorage": {
          "type": "object"
        }
      },
      "type": "object"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "type": "object"
}
