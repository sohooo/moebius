{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "apiVersion": {
      "const": "networking.k8s.io/v1"
    },
    "kind": {
      "const": "Ingress"
    },
    "metadata": {
      "properties": {
        "name": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "spec": {
      "properties": {
        "rules": {
          "items": {
            "properties": {
              "host": {
                "type": "string"
              },
              "http": {
                "properties": {
                  "paths": {
                    "items": {
                      "properties": {
                        "backend": {
                          "type": "object"
                        },
                        "path": {
                          "type": "string"
                        },
                        "pathType": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "pathType",
                        "backend"
                      ],
                      "type": "object"
                    },
                    "type": "array"
                  }
                },
                "type": "object"
              }
            },
            "type": "object"
          },
          "type": "array"
        }
      },
      "type": "object"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "type": "object"
}
