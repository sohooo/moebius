{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "apiVersion": {
      "const": "v1"
    },
    "kind": {
      "const": "Service"
    },
    "metadata": {
      "properties": {
        "name": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "spec": {
      "properties": {
        "ports": {
          "items": {
            "properties": {
              "port": {
                "type": "integer"
              },
              "targetPort": {
                "type": [
                  "integer",
                  "string"
                ]
              }
            },
            "required": [
              "port"
            ],
            "type": "object"
          },
          "type": "array"
        },
        "type": {
          "type": "string"
        }
      },
      "required": [
        "ports"
      ],
      "type": "object"
    }
  },
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "type": "object"
}
